{
  "psa_framework_version": 1.1,
  "name": "TFM_SP_LP",
  "type": "APPLICATION-ROT",
  "priority": "NORMAL",
  "model": "${SPM_BACKEND}",
  # entry_point below is ignored when using the SFN backend
  "entry_point": "tfm_lp_req_mngr_init",
  "stack_size": "0x0400",

  # Service definitions for IPC model.
  "services": [
    {
      "name": "TFM_LP_LED_TOGGLE",

      # Bits [31:12] denote the vendor (change this for your own vendor id),
      # bits [11:0] are arbitrary at the discretion of the vendor.
      "sid": "0xFFFFF010",
      "non_secure_clients": true,
      # Make the service connection based.
      # Requires CONFIG_TFM_CONNECTION_BASED_SERVICE_API to be enabled.
      "connection_based": true,
      "version": 1,
      "version_policy": "STRICT",
    }
  ]
}