{
  "description": "TF-M secure partition manifests",
  "type": "manifest_list",
  "version_major": 0,
  "version_minor": 1,
  "pid": 1000,
  "manifest_list": [
    {
      "description": "LED Partition",
      "short_name": "TFM_LP",
      "manifest": "${CMAKE_CURRENT_BINARY_DIR}/led_partition/tfm_led_partition.yaml",
      "output_path": "${TFM_BINARY_DIR}/led_partition",
      "tfm_partition_ipc": true,
      "version_major": 0,
      "version_minor": 1,
      "linker_pattern": {
        "library_list": [
           "*tfm_*partition_lp.*"
         ],
      }
    },
  ]
}